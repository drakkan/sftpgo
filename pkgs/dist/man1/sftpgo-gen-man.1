.TH "SFTPGO-GEN-MAN" "1" "Mar 2026" "SFTPGo 2.7.99-dev" "SFTPGo Manual"

.SH NAME
sftpgo-gen-man - Generate man pages for sftpgo


.SH SYNOPSIS
\fBsftpgo gen man [flags]\fP


.SH DESCRIPTION
This command automatically generates up-to-date man pages of SFTPGo's
command-line interface.
By default, it creates the man page files in the "man" directory under the
current directory.


.SH OPTIONS
\fB-d\fP, \fB--dir\fP="man"
	The directory to write the man pages

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for man


.SH SEE ALSO
\fBsftpgo-gen(1)\fP
